generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          String    @id @default(cuid())
  taskNumber  Int       @unique @default(autoincrement())
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  order        Int       @default(0)
  archived    Boolean   @default(false)
  status      Status    @default(TODO)
  statusChangedAt DateTime @default(now())
  myPrUrls         String[]  @default([])
  githubPrUrls     String[]  @default([])
  azureWorkItemUrl String?
  azureDepUrls     String[]  @default([])
  myIssueUrls      String[]  @default([])
  githubIssueUrls  String[]  @default([])
  labels          Label[]          @relation("LabelToTodo")
  subtasks        Subtask[]
  accomplishment  Accomplishment?
  contacts        TodoContact[]
  statusUpdates   StatusUpdate[]
  sessions        Session[]
  notebookNoteId  String?        @unique
  notebookNote    NotebookNote?  @relation(fields: [notebookNoteId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([archived])
  @@index([priority])
  @@index([dueDate])
  @@index([order])
  @@index([completedAt])
  // Supports the board query (active / completed / deleted slices)
  // which always filters by archived AND status together.
  @@index([archived, status])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([todoId])
}

model Label {
  id                 String   @id @default(cuid())
  name               String   @unique
  color              String   @default("#22c55e")
  billingType        String?
  billingCode        String?
  billingDescription String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  todos              Todo[]   @relation("LabelToTodo")
  billingCodes       BillingCode[]
}

model BillingCode {
  id          String   @id @default(cuid())
  type        String
  code        String
  description String?
  order       Int      @default(0)
  labelId     String
  label       Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([labelId, order])
  @@unique([labelId, code])
}

model Note {
  id        String   @id @default("default")
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  TODO
  IN_PROGRESS
  WAITING
  UNDER_REVIEW
  ON_HOLD
  BLOCKED
  COMPLETED
  CANCELLED
}

model NotebookNote {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todo      Todo?

  @@index([updatedAt])
  @@index([pinned])
  @@index([archived])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Person {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todoContacts TodoContact[]
}

model TodoContact {
  id       String @id @default(cuid())
  role     String
  order    Int    @default(0)
  todoId   String
  todo     Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([todoId, personId])
  @@index([todoId])
  @@index([personId])
}

model StatusUpdate {
  id        String   @id @default(cuid())
  content   String
  status    Status?
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([todoId])
  @@index([createdAt])
}

model Session {
  id          String   @id @default(cuid())
  tool        String   // "claude" | "codex"
  command     String
  workingPath String
  createdAt   DateTime @default(now())
  todoId      String
  todo        Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId])
  @@index([createdAt])
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
}

model ChatThread {
  id        String        @id @default(cuid())
  title     String        @default("New chat")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([updatedAt])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      ChatRole
  parts     Json
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
}

enum AccomplishmentCategory {
  DELIVERY
  HIRING
  MENTORING
  COLLABORATION
  GROWTH
  OTHER
}

model Accomplishment {
  id          String                  @id @default(cuid())
  title       String
  description String?
  category    AccomplishmentCategory
  date        DateTime
  year        Int
  todoId      String?                 @unique
  todo        Todo?                   @relation(fields: [todoId], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([year])
  @@index([category])
}
