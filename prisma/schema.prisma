generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          String    @id @default(cuid())
  taskNumber  Int       @unique @default(autoincrement())
  title       String
  description String?
  priority    Priority  @default(MEDIUM)
  dueDate     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?
  order        Int       @default(0)
  archived    Boolean   @default(false)
  status      Status    @default(TODO)
  myPrUrls         String[]  @default([])
  githubPrUrls     String[]  @default([])
  azureWorkItemUrl String?
  azureDepUrls     String[]  @default([])
  myIssueUrls      String[]  @default([])
  githubIssueUrls  String[]  @default([])
  labels          Label[]          @relation("LabelToTodo")
  subtasks        Subtask[]
  accomplishment  Accomplishment?
  contacts        TodoContact[]
  notebookNoteId  String?        @unique
  notebookNote    NotebookNote?  @relation(fields: [notebookNoteId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([archived])
  @@index([priority])
  @@index([dueDate])
  @@index([order])
  @@index([completedAt])
}

model Subtask {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  order     Int      @default(0)
  todoId    String
  todo      Todo     @relation(fields: [todoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([todoId])
}

model Label {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#22c55e")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todos     Todo[]   @relation("LabelToTodo")
}

model Note {
  id        String   @id @default("default")
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  TODO
  IN_PROGRESS
  WAITING
  UNDER_REVIEW
  ON_HOLD
  COMPLETED
}

model NotebookNote {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todo      Todo?

  @@index([updatedAt])
  @@index([pinned])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Person {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  todoContacts TodoContact[]
}

model TodoContact {
  id       String @id @default(cuid())
  role     String
  order    Int    @default(0)
  todoId   String
  todo     Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([todoId, personId])
  @@index([todoId])
  @@index([personId])
}

enum AccomplishmentCategory {
  DELIVERY
  HIRING
  MENTORING
  COLLABORATION
  GROWTH
  OTHER
}

model Accomplishment {
  id          String                  @id @default(cuid())
  title       String
  description String?
  category    AccomplishmentCategory
  date        DateTime
  year        Int
  todoId      String?                 @unique
  todo        Todo?                   @relation(fields: [todoId], references: [id], onDelete: SetNull)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([year])
  @@index([category])
}
